:root {
    --bg-dark: #0a080d;
    --card-bg: rgba(22, 16, 28, 0.75);
    --pyro-red: #ff3b3f;
    --pyro-orange: #ff7844;
    --gold-accent: #f4c430;
    --ghost-cyan: #80deea;
    --text-main: #f0eaf8;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    scroll-behavior: smooth;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    font-family: 'Plus Jakarta Sans', sans-serif;
    overflow-x: hidden;
}

/* Background Canvas Particle */
#particle-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
}

/* --- SPOTIFY STYLE TOP PLAYER --- */
.spotify-bar {
    position: fixed;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 650px;
    background: rgba(18, 18, 18, 0.85);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 2px solid var(--pyro-red);
    border-radius: 16px;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 1000;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8), 0 0 15px rgba(255, 59, 63, 0.2);
    transition: top 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.spotify-bar.active {
    top: 15px;
}

.spotify-info {
    display: flex;
    align-items: center;
    gap: 14px;
}

.album-art {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: #222;
    border: 2px solid var(--gold-accent);
    animation: spin 8s linear infinite;
    animation-play-state: paused;
    object-fit: cover;
}

.spotify-bar.playing .album-art {
    animation-play-state: running;
}

@keyframes spin {
    100% { transform: rotate(360deg); }
}

.track-details h4 {
    font-size: 0.9rem;
    color: #fff;
    margin-bottom: 2px;
}

.track-details p {
    font-size: 0.75rem;
    color: #aaa;
}

.spotify-controls {
    display: flex;
    align-items: center;
    gap: 12px;
}

.play-btn {
    background: var(--pyro-red);
    border: none;
    color: #fff;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: transform 0.2s, background 0.2s;
}

.play-btn:hover {
    transform: scale(1.1);
    background: var(--pyro-orange);
}

/* --- HERO SECTION --- */
header.hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 20px;
    position: relative;
}

.hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    background: linear-gradient(135deg, #fff 0%, var(--gold-accent) 50%, var(--pyro-red) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 30px rgba(255, 59, 63, 0.3);
    margin-bottom: 10px;
}

.hero-subtitle {
    font-size: 1.1rem;
    letter-spacing: 2px;
    color: #ccc;
    margin-bottom: 30px;
    text-transform: uppercase;
}

.gif-container {
    position: relative;
    width: 320px;
    height: 320px;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid rgba(255, 59, 63, 0.4);
    box-shadow: 0 0 40px rgba(255, 59, 63, 0.3), inset 0 0 20px rgba(0,0,0,0.5);
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.gif-container:hover {
    transform: translateY(-8px) scale(1.02);
    border-color: var(--gold-accent);
}

.gif-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* --- SECTIONS & SCROLL ANIMATION --- */
section {
    max-width: 1000px;
    margin: 80px auto;
    padding: 40px 20px;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}

section.visible {
    opacity: 1;
    transform: translateY(0);
}

.card {
    background: var(--card-bg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 30px;
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.section-heading {
    font-family: 'Cinzel', serif;
    font-size: 2rem;
    color: var(--gold-accent);
    margin-bottom: 20px;
    border-bottom: 2px solid var(--pyro-red);
    display: inline-block;
    padding-bottom: 5px;
}

/* --- BOO TAO INTERACTIVE GHOST --- */
.ghost-interactive {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 80px;
    height: 80px;
    cursor: pointer;
    z-index: 99;
    animation: float 3s ease-in-out infinite;
    filter: drop-shadow(0 0 15px var(--ghost-cyan));
    transition: transform 0.2s;
}

.ghost-interactive:active {
    transform: scale(0.85);
}

@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
}

.speech-bubble {
    position: fixed;
    bottom: 120px;
    right: 30px;
    background: #fff;
    color: #111;
    padding: 12px 18px;
    border-radius: 15px;
    font-weight: 600;
    font-size: 0.85rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.4);
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    pointer-events: none;
    max-width: 220px;
    z-index: 100;
}

.speech-bubble.show {
    opacity: 1;
    transform: translateY(0);
}

/* --- INTERACTIVE PROMO BUTTON --- */
.btn-action {
    margin-top: 20px;
    background: linear-gradient(45deg, var(--pyro-red), var(--pyro-orange));
    color: #fff;
    border: none;
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(255, 59, 63, 0.4);
    transition: all 0.3s;
}

.btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 59, 63, 0.7);
}

/* Responsive */
@media (max-width: 600px) {
    .spotify-bar { width: 95%; }
    .gif-container { width: 260px; height: 260px; }
}
